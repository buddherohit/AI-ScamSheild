# ==============================================================================
# AI ScamShield - Environment Configuration Template
# Copy this file to '.env' and fill in the values for local development.
# ==============================================================================

# ------------------------------------------------------------------------------
# System & Infrastructure Configurations
# ------------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=ai-scamshield

# ------------------------------------------------------------------------------
# MySQL Database Configurations
# ------------------------------------------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_NAME=scamshield_db
DB_USER=scamshield_admin
DB_PASSWORD=YourSecureSuperPassword123!

# ------------------------------------------------------------------------------
# Backend Spring Boot Configuration
# ------------------------------------------------------------------------------
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ------------------------------------------------------------------------------
# Security & JWT Token Setup
# ------------------------------------------------------------------------------
# JWT secret must be Base64-encoded, minimum 256 bits (32 bytes) for HS256 / 512 bits for HS512.
# Generate one using command: openssl rand -base64 64
JWT_SECRET=U29tZVN1cGVyU2VjcmV0S2V5Rm9yQUlTY2FtU2hpZWxkUGhhc2UxRm91bmRhdGlvblNldHVwMTIzNDU2Nzg5MA==
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ------------------------------------------------------------------------------
# Frontend React / Vite Configuration
# ------------------------------------------------------------------------------
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080/api/v1

# ------------------------------------------------------------------------------
# AI Integration & Third-Party APIs (Placeholders for Future Phases)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here-placeholder
OPENAI_MODEL=gpt-4o
UPI_VERIFICATION_PARTNER_KEY=mock-upi-key-placeholder
SMS_ROUTING_SERVICE_TOKEN=mock-sms-token-placeholder
